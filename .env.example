# ── Required ──────────────────────────────────────────────────────────────────
# Only this is needed to run the local chat UI.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Claude models (defaults shown) ──────────────────────────────────
CLAUDE_CHAT_MODEL=claude-opus-4-6           # used in the UI chat
CLAUDE_CALL_MODEL=claude-haiku-4-5-20251001 # used for call script generation

# ── Optional: ElevenLabs (enables voice playback in the UI) ──────────────────
# Without these, the 🔊 Listen button is hidden.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=          # e.g. 21m00Tcm4TlvDq8ikWAM (Rachel)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Optional: Telegram (enables the Telegram bot interface) ──────────────────
# Without this, only the local UI runs.
TELEGRAM_BOT_TOKEN=           # from @BotFather on Telegram

# ── Optional: Vapi (enables outbound phone calls) ────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# ── Optional: CRM live lookup ────────────────────────────────────────────────
CRM_API_BASE_URL=
CRM_API_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000  # change to your public URL in production
PORT=8000
